# Copy to ~/.env (the app loads this file automatically).
# All variables are optional unless noted.

# LLM features (required for agent mode and LLM-backed demos)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Data
TS_AGENTS_DATA_DIR=./data
TS_AGENTS_USE_TEST_DATA=true
TS_AGENTS_TEST_DATA_FILE=short_real.csv

# Sandbox backend: local | subprocess | docker | daytona | modal
TS_AGENTS_SANDBOX_MODE=local

# Daytona auth (cloud sandbox)
DAYTONA_API_KEY=
# Optional Daytona endpoint overrides:
# DAYTONA_API_URL=
# DAYTONA_TARGET=
# Optional snapshot override for sandbox bootstrap:
# TS_AGENTS_DAYTONA_SNAPSHOT=daytonaio/sandbox:0.4.3
# Optional: stream bootstrap and runner logs to stderr (default true)
# TS_AGENTS_DAYTONA_STREAM=true
# Optional: append Daytona stream logs to a file
# TS_AGENTS_DAYTONA_LOG_FILE=outputs/logs/daytona.log

# Modal auth (cloud sandbox)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_ENVIRONMENT=main
# Optional: stream Modal logs (default true)
# TS_AGENTS_MODAL_STREAM=true
# Optional: include timestamps in modal log stream
# TS_AGENTS_MODAL_LOG_TIMESTAMPS=false
# Optional: append Modal stream logs to a file
# TS_AGENTS_MODAL_LOG_FILE=outputs/logs/modal.log

# Modal function lookup (for --sandbox modal)
TS_AGENTS_MODAL_APP=ts-agents-sandbox
TS_AGENTS_MODAL_FUNCTION=run_tool
