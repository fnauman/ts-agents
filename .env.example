# Copy to ~/.env (the app loads this file automatically).
# All variables are optional unless noted.

# LLM features (required for agent mode and LLM-backed demos)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Data
TS_AGENTS_DATA_DIR=./data
TS_AGENTS_USE_TEST_DATA=true
TS_AGENTS_TEST_DATA_FILE=short_real.csv

# Sandbox backend: local | subprocess | docker | daytona | modal
TS_AGENTS_SANDBOX_MODE=local
